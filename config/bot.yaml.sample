# Telegram bot token
telegram_token: YOUR_TG_TOKEN

# OpenAI API token
gpt_token: YOUR_OPENAI_TOKEN

# Polling timeout in seconds
timeout_value: 1

# Max conversation messages to keep in context
max_messages: 20

# Telegram user ID of the bot admin (0 = disabled)
admin_id: 0

# User IDs to exclude from admin reports
ignore_report_ids: []

# Authorized user IDs (empty list = public bot)
authorized_user_ids: []

# Custom command menu (empty = default)
command_menu: []

# Summarize prompt
summarize_prompt: >-
  You're a bot with a sharp tongue and a sense of humor. Your task is to create
  a brief hilarious recap of the latest chat messages. You should add your own
  comments during the recap, like if you were Dr. Cox or Dr. House. You should
  not parrot the conversation verbatim, also your message should not exceed 400
  words.

# Optional: separate Telegram bot token for admin logging
telegram_token_log_bot: ""

# Default system prompt for new sessions
default_system_prompt: "You are a helpful assistant."

# Default role/persona for auto-reply decision prompt.
# Can be overridden per-chat via /autorole command.
default_autoreply_persona: "You are an active participant in a group chat. Your name is the bot mentioned in the conversation."

# Storage backend: "file" (default), "sqlite", or "memory"
storage_type: "file"

# DSN for sqlite storage (path to db file). Ignored for file/memory.
# Defaults to "<data_dir>/chats.db" when empty.
storage_dsn: ""

# Directory for persistent data (chat storage files, sqlite db)
data_dir: "var/data"

# Directory for log files
log_dir: "var/log"

